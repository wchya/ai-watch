# Browser address: http://127.0.0.1:${AI_WATCH_PORT}
AI_WATCH_PORT=8787

# Redis is available to the host at 127.0.0.1:${REDIS_PORT}; containers use
# the Compose service address redis:6379.
AI_WATCH_REDIS_URL=redis://redis:6379/0
AI_WATCH_REDIS_REQUIRED=true
# Optional 32-byte key encoded as base64 or hex. Leave empty to generate
# /data/master.key once with mode 0600 in the persistent AI Watch volume.
AI_WATCH_MASTER_KEY=
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
REDIS_MEM_LIMIT=512m
REDIS_MAX_MEMORY=384mb

# Private Mihomo sidecar used by provider probes. Its proxy/controller ports are
# available only inside the Compose network and are not published to the host.
MIHOMO_IMAGE=metacubex/mihomo:latest
MIHOMO_MEM_LIMIT=256m
MIHOMO_CONFIG_FILE=./config/mihomo/config.yaml.example
AI_WATCH_DEFAULT_PROXY_URL=http://mihomo:7890
AI_WATCH_HTTP_PROXY=http://mihomo:7890
AI_WATCH_HTTPS_PROXY=http://mihomo:7890
AI_WATCH_ALL_PROXY=socks5://mihomo:7891
AI_WATCH_NO_PROXY=localhost,127.0.0.1,::1,ai-watch,redis,mihomo

# Host configuration directories. Defaults use the current user's HOME.
# Set absolute paths when Docker Compose does not inherit HOME as expected.
# CC Switch is read only during application startup and atomically synced into
# Redis. Jobs use the last successful Redis snapshot and never query SQLite.
# CODEX_CONFIG_DIR=/Users/you/.codex
# CLAUDE_CONFIG_DIR=/Users/you/.claude
# CC_SWITCH_CONFIG_DIR=/Users/you/.cc-switch
AI_WATCH_CC_SWITCH_SYNC_TIMEOUT_SECONDS=10
# In-memory workspace for concurrent job credentials/configuration and temporary
# CC Switch database snapshots. Increase this if jobs report ENOSPC under /run/ai-watch.
AI_WATCH_RUNTIME_TMPFS_SIZE=256m

# Optional server-side DingTalk notification secret. Never expose or commit it.
DINGTALK_WEBHOOK_URL=

# Optional environment-only current Provider configuration.
OPENAI_API_KEY=
CODEX_API_KEY=
OPENAI_BASE_URL=
CODEX_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_CODE_USE_BEDROCK=
CLAUDE_CODE_USE_VERTEX=
ANTHROPIC_MODEL=

# Optional reproducible CLI versions. "latest" is convenient for local builds.
CODEX_CLI_VERSION=latest
CLAUDE_CLI_VERSION=latest
DEBIAN_MIRROR=http://mirrors.aliyun.com
NPM_REGISTRY=https://registry.npmmirror.com
# Public ECR avoids relying on Docker Hub's authentication endpoint.
NODE_BASE_IMAGE=public.ecr.aws/docker/library/node:22-bookworm-slim
GO_BASE_IMAGE=public.ecr.aws/docker/library/golang:1.24-bookworm
