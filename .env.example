# Browser address: http://127.0.0.1:${AI_WATCH_PORT}
AI_WATCH_PORT=8787

# Internal Redis used for bounded configuration, events, and runtime metadata.
# Compose does not publish Redis to the host; change this only when pointing at
# an explicitly managed Redis service on the Docker network.
AI_WATCH_REDIS_URL=redis://redis:6379/0
AI_WATCH_REDIS_REQUIRED=true
REDIS_IMAGE=redis:7-alpine
REDIS_MEM_LIMIT=512m
REDIS_MAX_MEMORY=384mb

# Host configuration directories. Defaults use the current user's HOME.
# Set absolute paths when Docker Compose does not inherit HOME as expected.
# CODEX_CONFIG_DIR=/Users/you/.codex
# CLAUDE_CONFIG_DIR=/Users/you/.claude
# CC_SWITCH_CONFIG_DIR=/Users/you/.cc-switch

# Optional server-side DingTalk notification secret. Never expose or commit it.
DINGTALK_WEBHOOK_URL=

# Optional environment-only current Provider configuration.
OPENAI_API_KEY=
CODEX_API_KEY=
OPENAI_BASE_URL=
CODEX_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_CODE_USE_BEDROCK=
CLAUDE_CODE_USE_VERTEX=
ANTHROPIC_MODEL=

# Optional reproducible CLI versions. "latest" is convenient for local builds.
CODEX_CLI_VERSION=latest
CLAUDE_CLI_VERSION=latest
DEBIAN_MIRROR=http://mirrors.aliyun.com
NPM_REGISTRY=https://registry.npmmirror.com
# Public ECR avoids relying on Docker Hub's authentication endpoint.
NODE_BASE_IMAGE=public.ecr.aws/docker/library/node:22-bookworm-slim
GO_BASE_IMAGE=public.ecr.aws/docker/library/golang:1.24-bookworm
